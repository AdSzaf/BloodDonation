<?xml version='1.0' encoding='utf-8'?>
<objectModel
		xmlns='http://standards.ieee.org/IEEE1516-2010'
		xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
		xsi:schemaLocation='http://standards.ieee.org/IEEE1516-2010 http://standards.ieee.org/downloads/1516/1516.2-2010/IEEE1516-DIF-2010.xsd'>
	<modelIdentification>
		<name>BloodSupplySimulation</name>
		<type>FOM</type>
		<version>2.0</version>
	</modelIdentification>
	<objects>
		<objectClass>
			<name>HLAobjectRoot</name>
		</objectClass>
	</objects>
	<interactions>
		<interactionClass>
			<name>HLAinteractionRoot</name>

			<!-- BloodPoints -> Transport -->
			<interactionClass>
				<name>BloodCollected</name>
				<sharing>PublishSubscribe</sharing>
				<transportation>HLAreliable</transportation>
				<order>Receive</order>
				<semantics>Interakcja wysylana przez punkt poboru po pobraniu krwi od dawcy</semantics>
				<parameter>
					<name>bloodId</name>
					<dataType>HLAinteger32BE</dataType>
					<semantics>Unikalny identyfikator donacji</semantics>
				</parameter>
				<parameter>
					<name>bloodAmount</name>
					<dataType>HLAfloat32BE</dataType>
					<semantics>Objetosc pobranej krwi w litrach (standardowo 0.45)</semantics>
				</parameter>
				<parameter>
					<name>bloodType</name>
					<dataType>HLAASCIIstring</dataType>
					<semantics>Grupa krwi dawcy np. A_PLUS, 0_MINUS</semantics>
				</parameter>
				<parameter>
					<name>donationTime</name>
					<dataType>HLAfloat64BE</dataType>
					<semantics>Czas symulacyjny pobrania krwi</semantics>
				</parameter>
				<parameter>
					<name>isMobile</name>
					<dataType>HLAboolean</dataType>
					<semantics>True jesli krew pobrano w krwiobusie, False dla punktu stacjonarnego</semantics>
				</parameter>
			</interactionClass>

			<!-- Hospital -> Transport -->
			<interactionClass>
				<name>Request</name>
				<sharing>PublishSubscribe</sharing>
				<transportation>HLAreliable</transportation>
				<order>Receive</order>
				<semantics>Zapotrzebowanie szpitala na krew</semantics>
				<parameter>
					<name>requestId</name>
					<dataType>HLAinteger32BE</dataType>
					<semantics>Identyfikator zgloszenia zapotrzebowania</semantics>
				</parameter>
				<parameter>
					<name>hospitalId</name>
					<dataType>HLAinteger32BE</dataType>
					<semantics>Identyfikator szpitala zglaszajacego zapotrzebowanie</semantics>
				</parameter>
				<parameter>
					<name>bloodType</name>
					<dataType>HLAASCIIstring</dataType>
					<semantics>Pozadana grupa krwi</semantics>
				</parameter>
				<parameter>
					<name>requestedAmount</name>
					<dataType>HLAfloat32BE</dataType>
					<semantics>Wymagana ilosc krwi w litrach</semantics>
				</parameter>
				<parameter>
					<name>isUrgent</name>
					<dataType>HLAboolean</dataType>
					<semantics>True tryb nagly priorytetowy, False tryb planowy</semantics>
				</parameter>
			</interactionClass>

			<!-- Transport -> Hospital -->
			<interactionClass>
				<name>BloodTransported</name>
				<sharing>PublishSubscribe</sharing>
				<transportation>HLAreliable</transportation>
				<order>Receive</order>
				<semantics>Informacja o dostarczeniu krwi do szpitala</semantics>
				<parameter>
					<name>bloodId</name>
					<dataType>HLAinteger32BE</dataType>
					<semantics>Identyfikator dostarczonej paczki krwi</semantics>
				</parameter>
				<parameter>
					<name>hospitalId</name>
					<dataType>HLAinteger32BE</dataType>
					<semantics>Identyfikator szpitala docelowego</semantics>
				</parameter>
				<parameter>
					<name>requestId</name>
					<dataType>HLAinteger32BE</dataType>
					<semantics>ID zamowienia, ktore jest realizowane przez te dostawy</semantics>
				</parameter>
				<parameter>
					<name>bloodAmount</name>
					<dataType>HLAfloat32BE</dataType>
					<semantics>Objetosc dostarczonej krwi w litrach</semantics>
				</parameter>
				<parameter>
					<name>bloodType</name>
					<dataType>HLAASCIIstring</dataType>
					<semantics>Grupa krwi dostarczonej paczki</semantics>
				</parameter>
				<parameter>
					<name>donationTime</name>
					<dataType>HLAfloat64BE</dataType>
					<semantics>Pierwotny czas pobrania krwi umozliwia wyliczenie wieku krwi</semantics>
				</parameter>
			</interactionClass>

		</interactionClass>
	</interactions>
	<dimensions/>
	<synchronizations>
		<synchronizationPoint>
			<label>ReadyToRun</label>
			<dataType>NA</dataType>
			<capability>NA</capability>
			<semantics>Punkt synchronizacji - czekamy az wszystkie federaty dolacza</semantics>
		</synchronizationPoint>
	</synchronizations>
	<transportations/>
	<updateRates/>
	<dataTypes>
		<basicDataRepresentations/>
		<simpleDataTypes/>
		<enumeratedDataTypes/>
		<arrayDataTypes/>
		<fixedRecordDataTypes/>
		<variantRecordDataTypes/>
	</dataTypes>
	<notes/>
</objectModel>